# NEAMEE Auto-Tech — Laravel API on cPanel (document root = public/)

APP_NAME="NEAMEE Auto-Tech"
APP_ENV=production
# Leave empty on first deploy — cpanel-fix-api.sh runs: php artisan key:generate --force
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.neamee-autotechsolutions.com
ASSET_URL=

FRONTEND_URL=https://neamee-autotechsolutions.com
CORS_ALLOWED_ORIGINS=https://neamee-autotechsolutions.com,https://www.neamee-autotechsolutions.com
SANCTUM_STATEFUL_DOMAINS=neamee-autotechsolutions.com,www.neamee-autotechsolutions.com,localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# Run new migrations automatically on each web request when pending (safe for deploys)
AUTO_MIGRATE=true

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visawgnz_autotech
DB_USERNAME=visawgnz_auto_user
DB_PASSWORD=Autotech@2026

# file = simpler on cPanel; use database if you prefer (requires sessions table)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.neamee-autotechsolutions.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=neamee-autotechsolutions.com
MAIL_PORT=465
MAIL_USERNAME=info@neamee-autotechsolutions.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=info@neamee-autotechsolutions.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=info@neamee-autotechsolutions.com

STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
